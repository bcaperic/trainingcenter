# ─── PostgreSQL ───
POSTGRES_DB=training_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# ─── NestJS API ───
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/training_hub?schema=public
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CHECKIN_OPEN_MINUTES=10
CHECKIN_CLOSE_MINUTES=15
LATE_GRACE_MINUTES=5
ENROLL_CLOSE_MINUTES=60
API_PORT=3000
CORS_ORIGIN=http://localhost:8080

# ─── MinIO (S3-compatible) ───
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET=traininghub

# ─── Vite frontend ───
VITE_API_BASE_URL=/api
WEB_PORT=8080
